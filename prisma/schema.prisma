// RTD — Premium luxury airport concierge & transportation platform
// Prisma schema. Database: PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum UserRole {
  SUPERADMIN
  ADMIN
  EMPLOYEE
  DRIVER
}

enum Language {
  EN
  AR
}

/// Lifecycle of a concierge request, in business order.
enum RequestStatus {
  REQUEST_RECEIVED
  UNDER_REVIEW
  CLIENT_CONTACTED
  EMPLOYEE_ASSIGNED
  DRIVER_ASSIGNED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Operational status a driver progresses through for an assigned task.
enum DriverTaskStatus {
  PENDING
  ACCEPTED
  ON_THE_WAY
  ARRIVED
  COMPLETED
}

/// Service composition chosen per step.
enum ServiceType {
  CAR_ONLY
  MEET_ASSIST_ONLY
  FAST_TRACK_ONLY
  MEET_ASSIST_CAR
  MEET_ASSIST_FASTTRACK_CAR
  SKIP
}

enum VerificationChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum VerificationPurpose {
  PHONE
  EMAIL
}

/// Lifecycle of a request's price.
enum PriceStatus {
  ESTIMATED // customer-facing estimate from the pricing engine
  ADJUSTED // admin applied a discount/surcharge
  FINALIZED // admin confirmed a final price
}

/// Placeholder payment lifecycle (payment not implemented yet).
enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PriceChangeType {
  RECALCULATED
  OVERRIDE
  DISCOUNT
  SURCHARGE
}

/// How a journey step's flight details were obtained.
enum FlightLookupStatus {
  MANUAL // entered by hand, not verified
  VERIFIED // confirmed via the flight lookup provider
  LOOKUP_FAILED // lookup attempted but the flight wasn't found / API failed
}

// ─────────────────────────── Models ───────────────────────────

/// Staff accounts (admin / operations employee / driver). Customers are NOT users.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  // When true, the account has no usable password yet and must set one on first
  // login (used to bootstrap the superadmin without shipping a known secret).
  mustSetPassword Boolean @default(false)
  // One-time password-setup token (SHA-256 hash + expiry). The raw token is
  // emailed to the account owner; cleared once the password is set.
  setupTokenHash      String?
  setupTokenExpiresAt DateTime?
  // Presence: refreshed while the user's dashboard is open (via the polled
  // notifications action). "Online" = seen within the last couple of minutes.
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedAsEmployee Request[]       @relation("EmployeeAssignment")
  assignedAsDriver   Request[]       @relation("DriverAssignment")
  statusChanges      StatusHistory[]
  internalNotes      InternalNote[]
  auditLogs          AuditLog[]
  driverTasks        DriverTask[]
  priceChanges       RequestPriceHistory[]

  @@index([role])
}

/// The traveller who submits a request. Decoupled from User.
model Customer {
  id            String   @id @default(cuid())
  fullName      String
  phone         String // E.164 with country code
  phoneVerified Boolean  @default(false)
  email         String
  emailVerified Boolean  @default(false)
  language      Language @default(EN)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requests Request[]

  @@index([phone])
  @@index([email])
}

model Request {
  id              String        @id @default(cuid())
  referenceNumber String        @unique // e.g. RTD-2026-00045
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          RequestStatus @default(REQUEST_RECEIVED)

  selectedPackage   String? // package name snapshot for a package booking
  preferredLanguage Language     @default(EN)

  // Trip-level summary defaults (each step can override)
  carCategory String      @default("VIP") // vehicle class code (see VehicleCategory.category)
  passengers  Int         @default(1)
  bags        Int         @default(0)
  children    Boolean     @default(false)
  childSeat   Boolean     @default(false)

  // Trip-level information (collected once at the start of the journey)
  departureDate     DateTime?
  returnDate        DateTime?
  specialAssistance Boolean   @default(false)
  assistanceNotes   String?

  notes               String?
  contactMeInstead    Boolean @default(false) // "I don't know the details yet, please contact me"
  validationStatus    String  @default("PENDING") // PENDING | VALID | HAS_WARNINGS

  // ── Pricing ──
  currency       String        @default("SAR")
  estimatedTotal Int           @default(0) // engine estimate, in whole SAR
  finalPrice     Int? // admin-controlled final price
  priceStatus    PriceStatus   @default(ESTIMATED)
  paymentStatus  PaymentStatus @default(UNPAID)

  assignedEmployeeId String?
  assignedEmployee   User?   @relation("EmployeeAssignment", fields: [assignedEmployeeId], references: [id])
  assignedDriverId   String?
  assignedDriver     User?   @relation("DriverAssignment", fields: [assignedDriverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journeySteps  JourneyStep[]
  statusHistory StatusHistory[]
  internalNotes InternalNote[]
  driverTasks   DriverTask[]
  auditLogs     AuditLog[]
  priceHistory  RequestPriceHistory[]
  flightSnapshots FlightSnapshot[]

  @@index([status])
  @@index([assignedEmployeeId])
  @@index([assignedDriverId])
  @@index([createdAt])
}

model JourneyStep {
  id        String @id @default(cuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  stepOrder Int
  stepType  String

  city           String?
  airport        String?
  terminal       String?
  loungeType     String?
  flightNumber   String?
  scheduledAt    DateTime? // combined date + time
  endAt          DateTime? // for chauffeur / multi-day services
  pickupLocation String?
  dropoffLocation String?
  hotelName      String?
  hotelAddress   String?
  homeAddress    String?

  serviceType ServiceType @default(CAR_ONLY)
  carCategory String? // primary vehicle class code (see VehicleCategory.category)
  passengers  Int?
  bags        Int?
  // Extra vehicles booked alongside the primary one when a single car can't
  // carry the whole party: [{ carCategory, passengers, bags }]. Null/empty for
  // the common single-vehicle case.
  additionalVehicles Json?

  // chauffeur specifics
  days       Int?
  dailyHours Int?
  dailyUsage String? // SEVEN_HOURS | EIGHT_HOURS | FULL_DAY

  skipped Boolean @default(false)

  // ── Pricing (computed server-side; admin may adjust per step) ──
  basePrice          Int? // unit price for this service (per-day for chauffeur)
  computedPrice      Int? // engine result for this step
  adminAdjustedPrice Int? // optional per-step admin override

  // ── Flight lookup ──
  flightLookupStatus FlightLookupStatus @default(MANUAL)
  flightData         Json? // normalized flight payload (airline, terminals, times, status…)

  validationErrors   String[] @default([])
  validationWarnings String[] @default([])

  notes String?

  driverTask DriverTask?

  @@unique([requestId, stepOrder])
  @@index([requestId])
}

/// A driver-executable task derived from a transfer-type journey step.
model DriverTask {
  id            String           @id @default(cuid())
  requestId     String
  request       Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  journeyStepId String           @unique
  journeyStep   JourneyStep      @relation(fields: [journeyStepId], references: [id], onDelete: Cascade)
  driverId      String?
  driver        User?            @relation(fields: [driverId], references: [id])
  status        DriverTaskStatus @default(PENDING)
  driverNotes   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([driverId])
}

model VehicleCategory {
  id              String      @id @default(cuid())
  category        String      @unique // vehicle class code, e.g. VIP or a custom class
  nameEn          String
  nameAr          String
  maxPassengers   Int
  exampleModels   String
  descriptionEn   String
  descriptionAr   String
  isRecommended   Boolean     @default(false)
  sortOrder       Int         @default(0)
  active          Boolean     @default(true)
}

/// Admin-editable base price per service (journey step type), in whole SAR.
/// Admin-managed catalog of journey services (steps). Behavior is driven by the
/// feature flags + cityScope; `code` is the stable key used by pricing and steps.
model ServiceStep {
  id             String  @id @default(cuid())
  code           String  @unique
  nameEn         String
  nameAr         String
  shortNameEn    String
  shortNameAr    String
  descriptionEn  String
  descriptionAr  String
  sortOrder      Int     @default(0)
  cityScope      String  @default("DESTINATION") // RIYADH | DESTINATION | ANY
  featTransfer   Boolean @default(false)
  featAssistance Boolean @default(false)
  featFlight     Boolean @default(false)
  featHotel      Boolean @default(false)
  featHome       Boolean @default(false)
  featChauffeur  Boolean @default(false)
  createsDriverTask Boolean @default(false)
  active         Boolean @default(true)
}

/// Used for assistance / no-car services; car services are priced per class
/// via ServiceClassPrice.
model ServicePricing {
  id        String   @id @default(cuid())
  stepType  String @unique
  basePrice Int
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

/// Admin-entered price for a car service at a specific vehicle class (whole SAR).
/// Prices are direct amounts (no multipliers); the journey total is their sum.
model ServiceClassPrice {
  id       String   @id @default(cuid())
  stepType String
  category String // vehicle class code
  price    Int

  @@unique([stepType, category])
}

/// Per-city override of a car service's per-class price.
model CityServiceClassPrice {
  id       String @id @default(cuid())
  cityCode String
  city     City   @relation(fields: [cityCode], references: [code], onDelete: Cascade)
  stepType String
  category String
  price    Int

  @@unique([cityCode, stepType, category])
}

/// Admin-editable price per lounge / assistance option.
model LoungePricing {
  id         String  @id @default(cuid())
  loungeType String  @unique
  price      Int
  active     Boolean @default(true)
}

/// Audit trail of price changes on a request (override / discount / surcharge).
model RequestPriceHistory {
  id          String          @id @default(cuid())
  requestId   String
  request     Request         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  changeType  PriceChangeType
  oldPrice    Int?
  newPrice    Int
  reason      String?
  changedById String?
  changedBy   User?           @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([requestId])
}

/// A standalone package product (name + description + flat price). Booked
/// directly by the customer (notes optional) — not a bundle of journey steps.
model ServicePackage {
  id            String   @id @default(cuid())
  nameEn        String
  nameAr        String
  descriptionEn String
  descriptionAr String
  price         Int      @default(0)
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
}

model City {
  id        String   @id @default(cuid())
  code      String   @unique // RUH, LON, PAR, DXB, CAI
  nameEn    String
  nameAr    String
  country   String
  active    Boolean  @default(true)
  isOrigin  Boolean  @default(false) // Riyadh is the journey origin
  currency  String?
  approxDurationMinutes Int? // approx flight time from Riyadh
  notes     String?
  landmarkKey String? // admin-chosen landmark icon preset (see CityLandmark)
  airports  Airport[]
  servicePricing CityServicePricing[]
  loungePricing  CityLoungePricing[]
  vehiclePricing CityVehiclePricing[]
  serviceClassPricing CityServiceClassPrice[]
}

/// Per-city override of a service (journey step) base price + availability.
model CityServicePricing {
  id       String   @id @default(cuid())
  cityCode String
  city     City     @relation(fields: [cityCode], references: [code], onDelete: Cascade)
  stepType String
  price    Int? // null → use the global base price
  enabled  Boolean  @default(true) // false → service unavailable in this city

  @@unique([cityCode, stepType])
}

/// Per-city override of a lounge / airport-service price + availability.
model CityLoungePricing {
  id         String  @id @default(cuid())
  cityCode   String
  city       City    @relation(fields: [cityCode], references: [code], onDelete: Cascade)
  loungeType String
  price      Int? // null → use the global lounge price
  enabled    Boolean @default(true)

  @@unique([cityCode, loungeType])
}

/// Per-city override of a vehicle category's multiplier + availability.
model CityVehiclePricing {
  id         String      @id @default(cuid())
  cityCode   String
  city       City        @relation(fields: [cityCode], references: [code], onDelete: Cascade)
  category   String // vehicle class code (see VehicleCategory.category)
  enabled    Boolean     @default(true) // false → category not offered in this city

  @@unique([cityCode, category])
}

model Airport {
  id      String  @id @default(cuid())
  code    String  @unique // IATA
  nameEn  String
  nameAr  String
  cityId  String
  city    City    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  terminals String[] @default([])
  country  String?
  timezone String? // IANA, e.g. Asia/Riyadh
  utcOffsetMinutes Int @default(0) // offset for the schedule window (June 2026)
  lounges  AirportLounge[]
}

/// Admin-managed lounge / airport-assistance product (name + description of its
/// services and requirements). Offered at specific airports via AirportLounge.
model Lounge {
  id            String   @id @default(cuid())
  nameEn        String
  nameAr        String
  descriptionEn String   @default("")
  descriptionAr String   @default("")
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  airports      AirportLounge[]
}

/// A lounge offered at a specific airport, with its per-airport price. The admin
/// enables lounges and sets prices in the city page's airport section.
model AirportLounge {
  id          String  @id @default(cuid())
  airportCode String
  airport     Airport @relation(fields: [airportCode], references: [code], onDelete: Cascade)
  loungeId    String
  lounge      Lounge  @relation(fields: [loungeId], references: [id], onDelete: Cascade)
  enabled     Boolean @default(true)
  price       Int     @default(0)

  @@unique([airportCode, loungeId])
}

/// Airlines referenced by the static weekly flight schedule.
model Airline {
  id        String                 @id @default(cuid())
  code      String                 @unique // SV, EK, XY…
  name      String
  schedules WeeklyFlightSchedule[]
}

/// A direct route between two airports (by IATA code).
model Route {
  id                     String                 @id @default(cuid())
  originAirportCode      String
  destinationAirportCode String
  isDirect               Boolean                @default(true)
  approxDurationMinutes  Int
  schedules              WeeklyFlightSchedule[]

  @@unique([originAirportCode, destinationAirportCode])
}

/// One row per active weekday for a scheduled flight (static, not live data).
model WeeklyFlightSchedule {
  id                 String  @id @default(cuid())
  routeId            String
  route              Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  airlineId          String
  airline            Airline @relation(fields: [airlineId], references: [id], onDelete: Cascade)
  flightCode         String
  dayOfWeek          Int // 1=Mon … 7=Sun
  departureTimeLocal String // "HH:MM" local to the origin airport
  isActive           Boolean @default(true)
  sourceWeek         String
  sourceName         String
  isStaticSchedule   Boolean @default(true)

  @@index([flightCode])
  @@index([routeId])
  @@index([airlineId])
}

/// A snapshot of the flight as resolved at request time (preserved even if the
/// static schedule later changes).
model FlightSnapshot {
  id                        String   @id @default(cuid())
  requestId                 String
  request                   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  leg                       String // DEPARTURE | RETURN
  flightCode                String?
  airline                   String?
  originAirport             String?
  destinationAirport        String?
  departureDate             DateTime?
  departureTimeLocal        String?
  estimatedArrivalDate      DateTime?
  estimatedArrivalTimeLocal String?
  lookupSource              String // static_schedule | manual
  lookupStatus              String // static_matched | manual | not_found
  createdAt                 DateTime @default(now())

  @@index([requestId])
}

model Hotel {
  id      String  @id @default(cuid())
  name    String
  city    String
  address String?
  active  Boolean @default(true)

  @@index([city])
}

model StatusHistory {
  id         String         @id @default(cuid())
  requestId  String
  request    Request        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fromStatus RequestStatus?
  toStatus   RequestStatus
  changedById String?
  changedBy  User?          @relation(fields: [changedById], references: [id])
  reason     String?
  createdAt  DateTime       @default(now())

  @@index([requestId])
}

model InternalNote {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  body       String
  createdAt  DateTime @default(now())

  @@index([requestId])
}

model VerificationCode {
  id        String              @id @default(cuid())
  target    String // phone (E.164) or email
  purpose   VerificationPurpose
  channel   VerificationChannel
  codeHash  String
  expiresAt DateTime
  consumed  Boolean             @default(false)
  attempts  Int                 @default(0)
  createdAt DateTime            @default(now())

  @@index([target, purpose])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String // e.g. REQUEST_CREATED, STATUS_CHANGED, EMPLOYEE_ASSIGNED
  entity    String // e.g. Request
  entityId  String
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([requestId])
}

// Key/value store for superadmin-editable app configuration (WhatsApp number,
// ops-alert email, email provider + credentials). Secret values are stored
// encrypted; a missing key falls back to the corresponding env var.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
