# ───────────────────────────────────────────────────────────────
# RTD — Environment configuration
# Copy this file to `.env` and fill in real values.
# Never commit `.env`. No secrets are hardcoded in the codebase.
# ───────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rtd?schema=public"

# Auth — used to sign session JWTs (use a long random string, e.g. `openssl rand -base64 48`)
AUTH_SECRET="change-me-to-a-long-random-secret"
# Session lifetime in seconds (default 7 days)
SESSION_MAX_AGE="604800"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp official contact (public)
NEXT_PUBLIC_WHATSAPP_NUMBER="966550832444"
NEXT_PUBLIC_WHATSAPP_DISPLAY="+966 55 083 2444"

# ── Notification providers (abstracted) ─────────────────────────
# Provider selector: "console" (dev — prints codes to server log) | "twilio" | "smtp"
SMS_PROVIDER="console"
EMAIL_PROVIDER="console"

# Twilio (used when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TWILIO_WHATSAPP_FROM=""

# SMTP (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="RTD Concierge <no-reply@rtd.sa>"

# Verification
VERIFICATION_CODE_TTL_MINUTES="10"

# ── Flight lookup provider ─────────────────────────────────────
# Active provider: "static_schedule" (seeded CSV weekly schedule — default)
#   other options: "mock" | "aviationstack" | "amadeus" | "flightaware"
FLIGHT_LOOKUP_PROVIDER="static_schedule"
# Legacy selector kept for the future real-API providers.
FLIGHT_API_PROVIDER="mock"
FLIGHT_API_KEY=""
FLIGHT_API_BASE_URL=""
