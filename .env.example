# ───────────────────────────────────────────────────────────────
# RTD — Environment configuration
# Copy this file to `.env` and fill in real values.
# Never commit `.env`. No secrets are hardcoded in the codebase.
# ───────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rtd?schema=public"

# Auth — used to sign session JWTs (use a long random string, e.g. `openssl rand -base64 48`)
AUTH_SECRET="change-me-to-a-long-random-secret"
# Session lifetime in seconds (default 7 days)
SESSION_MAX_AGE="604800"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp official contact (public)
NEXT_PUBLIC_WHATSAPP_NUMBER="966550832444"
NEXT_PUBLIC_WHATSAPP_DISPLAY="+966 55 083 2444"

# ── Notification providers (abstracted) ─────────────────────────
# Provider selector: "console" (dev — prints codes to server log) | "twilio" | "smtp"
SMS_PROVIDER="console"
EMAIL_PROVIDER="console"

# Twilio (used when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TWILIO_WHATSAPP_FROM=""

# SMTP (used when EMAIL_PROVIDER=smtp) — works with any SMTP provider.
#
# Google Workspace (@ratbli.sa) via App Password:
#   1. On the sending mailbox (e.g. noreply@ratbli.sa) enable 2-Step Verification.
#   2. Create an App Password (Google Account → Security → App passwords).
#   3. Use the values below. SMTP_USER must be a real Workspace mailbox, and
#      EMAIL_FROM should be that same address (or a verified "Send mail as"
#      alias) or Google will rewrite it.
#   Workspace sending limit is ~2,000/day — far above what this app needs.
#
# Alternative — Google Workspace SMTP relay (if App Passwords are disabled, or
# for higher limits). Configure it in Admin console (Apps → Google Workspace →
# Gmail → Routing → SMTP relay service), then:
#   SMTP_HOST="smtp-relay.gmail.com"
#   If you allowlist the server's IP in the relay settings, leave SMTP_USER and
#   SMTP_PASSWORD blank (the sender authenticates by IP). Otherwise set them to
#   a Workspace mailbox + App Password as above.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@ratbli.sa"
SMTP_PASSWORD=""
EMAIL_FROM="RTD Concierge <noreply@ratbli.sa>"

# Verification
VERIFICATION_CODE_TTL_MINUTES="10"

# ── Ops alerts (new-request notifications) ─────────────────────
# Where to alert the operations team when a customer submits a request.
# Uses the SMS/EMAIL providers above. Leave both blank to only log the alert.
OPS_ALERT_EMAIL=""
OPS_ALERT_PHONE=""            # E.164, e.g. +9665xxxxxxxx
OPS_ALERT_SMS_CHANNEL="SMS"   # SMS | WHATSAPP
# How long a successful phone/email verification stays valid at submission (hours)
VERIFICATION_VALID_HOURS="24"

# ── Observability ──────────────────────────────────────────────
# Structured log level: "debug" | "info" | "warn" | "error"
# (default: "info" in production, "debug" otherwise)
LOG_LEVEL="debug"

# ── Seeding ────────────────────────────────────────────────────
# Password for the seeded staff accounts. MUST be set (to a strong value)
# before seeding any non-development environment; defaults to a demo password.
SEED_STAFF_PASSWORD=""

# ── Flight lookup provider ─────────────────────────────────────
# Active provider: "static_schedule" (seeded CSV weekly schedule — default)
#   other options: "mock" | "aviationstack" | "amadeus" | "flightaware"
FLIGHT_LOOKUP_PROVIDER="static_schedule"
# Legacy selector kept for the future real-API providers.
FLIGHT_API_PROVIDER="mock"
FLIGHT_API_KEY=""
FLIGHT_API_BASE_URL=""
